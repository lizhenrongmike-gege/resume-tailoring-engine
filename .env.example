# ── LLM credentials ──────────────────────────────────────────────
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Search tier toggles (true/false) ─────────────────────────────
TIER1_ENABLED=true
TIER2_ENABLED=true
TIER3_ENABLED=true

# ── JobSpy settings ──────────────────────────────────────────────
# Available sites: indeed, linkedin, google, zip_recruiter, glassdoor
# (glassdoor currently broken; bayt/bdjobs/naukri are non-US)
JOBSPY_SITES=indeed,linkedin,google,zip_recruiter

# Results per keyword per site
JOBSPY_RESULTS_PER_KEYWORD=15

# Job type filter (leave empty for all)
# Options: fulltime, parttime, internship, contract
JOBSPY_JOB_TYPE=fulltime

# Remote filter (leave empty for all)
# Options: true (remote only), false (on-site only), empty (all)
JOBSPY_IS_REMOTE=

# Search radius in miles from location (default: 50)
JOBSPY_DISTANCE=50

# Fetch full LinkedIn job descriptions (slower but better quality)
# Options: true, false
JOBSPY_LINKEDIN_FULL_DESC=true

# Description format: markdown or html
JOBSPY_DESC_FORMAT=markdown

# Country for Indeed/Glassdoor (default: USA)
JOBSPY_COUNTRY=USA

# ── LLM models (via LiteLLM — supports any provider) ─────────────
# Screening model (fast/cheap, filters irrelevant jobs)
SCREENING_MODEL=claude-haiku-4-5-20251001
# Ranking model (deep evaluation of screened jobs)
RANKING_MODEL=claude-sonnet-4-20250514

# Examples for other providers:
# SCREENING_MODEL=gpt-4o-mini
# RANKING_MODEL=gpt-4o
# SCREENING_MODEL=gemini/gemini-2.0-flash
# RANKING_MODEL=gemini/gemini-2.5-pro
# Set the relevant key for your provider if you switch:
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=...
